# Neon Postgres — HTTP serverless driver connection string.
# Must be a pooled/HTTP-capable URL, e.g.:
#   postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# Public base URL for the GCS audio bucket (plain public objects, no signing).
# Sample audioUrl values are expected to live under this base.
#   e.g. https://storage.googleapis.com/tts-arena-public
GCS_PUBLIC_BASE_URL=

# Shared secret guarding POST /api/cron/bt. Cloud Scheduler must send it as the
# 'x-cron-secret' request header. Generate a long random value.
CRON_SECRET=

# --- Optional: Cloudflare Turnstile bot mitigation -----------------------
# Public site key, exposed to the browser.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Secret key, server-side verification only. Leave blank to disable Turnstile.
TURNSTILE_SECRET=
